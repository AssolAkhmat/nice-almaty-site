{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/nice-almaty" }
  ],
  "functions": {
    "api/*.js": {
      "includeFiles": "data/**"
    },
    "api/wazzup-webhook.js": {
      "includeFiles": "data/**",
      "maxDuration": 120
    }
  }
}
